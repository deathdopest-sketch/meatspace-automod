# ── StumbleChat credentials ───────────────────────────────────────────────────
AUTOMOD_LOGIN_EMAIL=your@email.com
AUTOMOD_LOGIN_PASS=yourpassword

# ── Optional: custom bot nick (defaults to Enforcer) ─────────────────────────
# AUTOMOD_BOT_NICK=Enforcer

# ── Optional: custom Chrome path ─────────────────────────────────────────────
# BROWSER_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# ── Daily email digest (all optional — omit to disable) ──────────────────────
# AUTOMOD_EMAIL_TO=owner@yoursite.com
# AUTOMOD_EMAIL_FROM=automod@yoursite.com
# SMTP_HOST=mail.yoursite.com
# SMTP_PORT=587
# SMTP_USER=automod@yoursite.com
# SMTP_PASS=smtppassword
